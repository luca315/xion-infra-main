diagrams.domain.tld {
  reverse_proxy 127.0.0.1:3001
}

console.domain.tld {
  reverse_proxy 127.0.0.1:3002
}

status.domain.tld {
  reverse_proxy 127.0.0.1:3003
}

icecast.domain.tld {
  reverse_proxy 127.0.0.1:3004
}

# web server config example
website.tld {
  root * /var/www/website-tld
  file_server
}

# File server config example

website.tld {
  root * /var/www/website-tld
  file_server browse
}
